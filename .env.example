# ============================================================
# Log Analyzer — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores
# 3. NUNCA subas .env a GitHub (está en .gitignore)

# --- Claude API ---
# Obtenla en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# --- Base de datos (opcional, SQLite por default) ---
# Para SQLite local no necesitas cambiar nada
DATABASE_URL=sqlite:///data/log_analyzer.db

# Para PostgreSQL (Neon.tech gratis):
# DATABASE_URL=postgresql://usuario:password@host/dbname

# --- Configuración del detector ---
# Porcentaje esperado de anomalías en los datos (0.0 a 0.5)
ANOMALY_CONTAMINATION=0.05

# Umbral de brute force: fallos en 5 minutos para disparar alerta
BRUTE_FORCE_THRESHOLD=5

# --- Streamlit (solo necesario si despliegas en servidor propio) ---
# STREAMLIT_SERVER_PORT=8501
